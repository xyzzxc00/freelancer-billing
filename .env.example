# Supabase 專案設定（Project Settings → API / Database）
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="xxxxx"

# Prisma 連線字串，用 Supabase 的 connection pooling (port 6543) 給應用層用
DATABASE_URL="postgresql://postgres:xxxxx@xxxxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Prisma migrate 用的直連字串 (port 5432，不經過 pgbouncer)
DIRECT_URL="postgresql://postgres:xxxxx@xxxxx.supabase.co:5432/postgres"
