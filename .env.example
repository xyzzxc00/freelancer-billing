# Supabase 專案設定（Project Settings → API / Database）
NEXT_PUBLIC_SUPABASE_URL="https://xxxxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="xxxxx"

# Prisma 連線字串，用 Supabase 的 connection pooling (port 6543) 給應用層用
DATABASE_URL="postgresql://postgres:xxxxx@xxxxx.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Prisma migrate 用的直連字串 (port 5432，不經過 pgbouncer)
DIRECT_URL="postgresql://postgres:xxxxx@xxxxx.supabase.co:5432/postgres"

# Resend（Email 通知）— 前往 resend.com 取得 API key
RESEND_API_KEY="re_xxxxx"
# 寄件人 email，需先在 Resend 驗證 domain（例如 noreply@jieanbook.com）
RESEND_FROM_EMAIL="接案帳本 <noreply@jieanbook.com>"
# 每日寄信上限（選填，預設 90），用來在達到 Resend 方案限制前主動停止寄送
RESEND_DAILY_LIMIT="90"

# 意見回饋收件信箱（feedback 表單寄送目的地）
ADMIN_EMAIL="your@email.com"

# Vercel Cron 驗證 token — 隨機產生，同步填入 Vercel 環境變數
# 產生方式：openssl rand -base64 32
CRON_SECRET="your-random-secret-here"
