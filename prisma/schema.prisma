// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 對應 Supabase Auth 的 auth.users，這裡只存應用層需要的個人資料
model Profile {
  id                String   @id @default(uuid()) // 等於 supabase auth.users.id
  email             String   @unique
  name              String?
  bankName          String? // 收款銀行名稱，顯示在請款單 PDF
  bankBranch        String? // 分行
  bankAccount       String? // 帳號
  bankAccountHolder String? // 戶名
  createdAt         DateTime @default(now())

  clients           Client[]
  quotes            Quote[]
  receivables       Receivable[]
  transactions      Transaction[]
  quoteTemplates    QuoteTemplate[]
  expenseCategories ExpenseCategory[]
  recurringExpenses RecurringExpense[]
  incomeCategories  IncomeCategory[]
  recurringIncomes  RecurringIncome[]

  @@map("profiles")
}

model Client {
  id        String   @id @default(uuid())
  userId    String
  name      String
  contact   String? // email/電話/Line等聯絡方式自由文字
  note      String?
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes  Quote[]

  @@index([userId])
  @@map("clients")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum TaxMode {
  NONE // 未稅，原價顯示
  BUSINESS_5PCT // 營業稅5%（開發票）
  LABOR_INCOME_10PCT // 勞務報酬二代健保+10%代扣
}

model Quote {
  id             String      @id @default(uuid())
  userId         String
  clientId       String
  title          String
  status         QuoteStatus @default(DRAFT)
  taxMode        TaxMode     @default(NONE)
  notes          String?     // 備註，會顯示在報價單底部
  expiresAt      DateTime?   // 報價有效期限
  shareToken     String      @unique @default(uuid()) // 給客戶看的公開分享連結用
  depositPercent Int?        // 訂金比例 1-99，NULL 代表不分期，接受後整筆入應收款
  signerName     String?     // 客戶接受報價時填寫的姓名
  sentAt         DateTime?
  respondedAt    DateTime?
  viewedAt       DateTime?   // 客戶第一次開啟公開連結的時間
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  profile     Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client      Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items       QuoteItem[]
  receivables Receivable[]

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([sentAt])
  @@map("quotes")
}

model QuoteItem {
  id        String   @id @default(uuid())
  quoteId   String
  name      String
  unitPrice Decimal  @db.Decimal(12, 2)
  quantity  Decimal  @db.Decimal(12, 2) @default(1)
  sortOrder Int      @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

enum ReceivableStatus {
  PENDING
  PAID
}

enum ReceivableKind {
  FULL // 未分期，整筆報價金額
  DEPOSIT // 訂金
  FINAL // 尾款
}

model Receivable {
  id        String           @id @default(uuid())
  userId    String
  quoteId   String
  kind      ReceivableKind   @default(FULL)
  amount    Decimal          @db.Decimal(12, 2)
  status    ReceivableStatus @default(PENDING)
  dueDate   DateTime?
  paidAt    DateTime?
  createdAt DateTime         @default(now())

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  transaction Transaction?

  @@index([userId])
  @@index([quoteId])
  @@map("receivables")
}

model QuoteTemplate {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  profile Profile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   QuoteTemplateItem[]

  @@index([userId])
  @@map("quote_templates")
}

model QuoteTemplateItem {
  id         String  @id @default(uuid())
  templateId String
  name       String
  unitPrice  Decimal @db.Decimal(12, 2)
  quantity   Decimal @db.Decimal(12, 2) @default(1)
  sortOrder  Int     @default(0)

  template QuoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("quote_template_items")
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  category        String? // 自由文字分類（舊資料、自動產生的記錄用）
  categoryId      String? // 支出分類
  incomeCategoryId String? // 收入分類
  note            String?
  receiptUrl      String? // 支出憑證照片，Supabase Storage 的 object path（非完整 URL）
  receivableId    String? @unique // 由 markReceivablePaidAction 建立時回填，用來讓刪除這筆收入時能連動把應收款改回待收款
  occurredAt      DateTime
  createdAt       DateTime        @default(now())

  profile         Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenseCategory ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  incomeCategory  IncomeCategory?  @relation(fields: [incomeCategoryId], references: [id], onDelete: SetNull)
  receivable      Receivable?      @relation(fields: [receivableId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([occurredAt])
  @@index([categoryId])
  @@index([incomeCategoryId])
  @@map("transactions")
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  profile           Profile            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  recurringExpenses RecurringExpense[]

  @@unique([userId, name])
  @@index([userId])
  @@map("expense_categories")
}

model RecurringExpense {
  id                   String    @id @default(uuid())
  userId               String
  name                 String
  amount               Decimal   @db.Decimal(12, 2)
  categoryId           String?
  dayOfMonth           Int // 1-28，每月固定哪天自動產生支出記錄
  active               Boolean   @default(true)
  lastGeneratedYearMonth String? // "2026-06"，避免同月重複產生
  createdAt            DateTime  @default(now())

  profile  Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("recurring_expenses")
}

model IncomeCategory {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  profile          Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  recurringIncomes RecurringIncome[]

  @@unique([userId, name])
  @@index([userId])
  @@map("income_categories")
}

model RecurringIncome {
  id                     String   @id @default(uuid())
  userId                 String
  name                   String
  amount                 Decimal  @db.Decimal(12, 2)
  categoryId             String?
  dayOfMonth             Int // 1-28，每月固定哪天自動產生收入記錄
  active                 Boolean  @default(true)
  lastGeneratedYearMonth String? // "2026-06"，避免同月重複產生
  createdAt              DateTime @default(now())

  profile  Profile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category IncomeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("recurring_incomes")
}

// 內部系統日誌，用來監控當日 Resend 寄送量（避免超過方案限制）並稽核寄送結果
model EmailLog {
  id      String   @id @default(uuid())
  sentAt  DateTime @default(now())
  to      String?
  subject String?
  status  String   @default("sent") // "sent" | "failed"
  error   String?

  @@index([sentAt])
  @@map("email_logs")
}
