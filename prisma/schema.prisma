// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 對應 Supabase Auth 的 auth.users，這裡只存應用層需要的個人資料
model Profile {
  id        String   @id @default(uuid()) // 等於 supabase auth.users.id
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  clients           Client[]
  quotes            Quote[]
  receivables       Receivable[]
  transactions      Transaction[]
  quoteTemplates    QuoteTemplate[]
  expenseCategories ExpenseCategory[]
  recurringExpenses RecurringExpense[]
  incomeCategories  IncomeCategory[]
  recurringIncomes  RecurringIncome[]

  @@map("profiles")
}

model Client {
  id        String   @id @default(uuid())
  userId    String
  name      String
  contact   String? // email/電話/Line等聯絡方式自由文字
  note      String?
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes  Quote[]

  @@index([userId])
  @@map("clients")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum TaxMode {
  NONE // 未稅，原價顯示
  BUSINESS_5PCT // 營業稅5%（開發票）
  LABOR_INCOME_10PCT // 勞務報酬二代健保+10%代扣
}

model Quote {
  id          String      @id @default(uuid())
  userId      String
  clientId    String
  title       String
  status      QuoteStatus @default(DRAFT)
  taxMode     TaxMode     @default(NONE)
  notes       String?     // 備註，會顯示在報價單底部
  expiresAt   DateTime?   // 報價有效期限
  shareToken  String      @unique @default(uuid()) // 給客戶看的公開分享連結用
  sentAt      DateTime?
  respondedAt DateTime?
  viewedAt    DateTime?   // 客戶第一次開啟公開連結的時間
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  profile    Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items      QuoteItem[]
  receivable Receivable?

  @@index([userId])
  @@index([clientId])
  @@index([status])
  @@index([sentAt])
  @@map("quotes")
}

model QuoteItem {
  id        String   @id @default(uuid())
  quoteId   String
  name      String
  unitPrice Decimal  @db.Decimal(12, 2)
  quantity  Decimal  @db.Decimal(12, 2) @default(1)
  sortOrder Int      @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

enum ReceivableStatus {
  PENDING
  PAID
}

model Receivable {
  id        String           @id @default(uuid())
  userId    String
  quoteId   String           @unique
  amount    Decimal          @db.Decimal(12, 2)
  status    ReceivableStatus @default(PENDING)
  dueDate   DateTime?
  paidAt    DateTime?
  createdAt DateTime         @default(now())

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("receivables")
}

model QuoteTemplate {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  profile Profile             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items   QuoteTemplateItem[]

  @@index([userId])
  @@map("quote_templates")
}

model QuoteTemplateItem {
  id         String  @id @default(uuid())
  templateId String
  name       String
  unitPrice  Decimal @db.Decimal(12, 2)
  quantity   Decimal @db.Decimal(12, 2) @default(1)
  sortOrder  Int     @default(0)

  template QuoteTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)

  @@index([templateId])
  @@map("quote_template_items")
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  category        String? // 自由文字分類（舊資料、自動產生的記錄用）
  categoryId      String? // 支出分類
  incomeCategoryId String? // 收入分類
  note            String?
  occurredAt      DateTime
  createdAt       DateTime        @default(now())

  profile         Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  expenseCategory ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  incomeCategory  IncomeCategory?  @relation(fields: [incomeCategoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([occurredAt])
  @@index([categoryId])
  @@index([incomeCategoryId])
  @@map("transactions")
}

model ExpenseCategory {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  profile           Profile            @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions      Transaction[]
  recurringExpenses RecurringExpense[]

  @@unique([userId, name])
  @@index([userId])
  @@map("expense_categories")
}

model RecurringExpense {
  id                   String    @id @default(uuid())
  userId               String
  name                 String
  amount               Decimal   @db.Decimal(12, 2)
  categoryId           String?
  dayOfMonth           Int // 1-28，每月固定哪天自動產生支出記錄
  active               Boolean   @default(true)
  lastGeneratedYearMonth String? // "2026-06"，避免同月重複產生
  createdAt            DateTime  @default(now())

  profile  Profile          @relation(fields: [userId], references: [id], onDelete: Cascade)
  category ExpenseCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("recurring_expenses")
}

model IncomeCategory {
  id        String   @id @default(uuid())
  userId    String
  name      String
  createdAt DateTime @default(now())

  profile          Profile           @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions     Transaction[]
  recurringIncomes RecurringIncome[]

  @@unique([userId, name])
  @@index([userId])
  @@map("income_categories")
}

model RecurringIncome {
  id                     String   @id @default(uuid())
  userId                 String
  name                   String
  amount                 Decimal  @db.Decimal(12, 2)
  categoryId             String?
  dayOfMonth             Int // 1-28，每月固定哪天自動產生收入記錄
  active                 Boolean  @default(true)
  lastGeneratedYearMonth String? // "2026-06"，避免同月重複產生
  createdAt              DateTime @default(now())

  profile  Profile         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category IncomeCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@map("recurring_incomes")
}
