// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// 對應 Supabase Auth 的 auth.users，這裡只存應用層需要的個人資料
model Profile {
  id        String   @id @default(uuid()) // 等於 supabase auth.users.id
  email     String   @unique
  name      String?
  createdAt DateTime @default(now())

  clients      Client[]
  quotes       Quote[]
  receivables  Receivable[]
  transactions Transaction[]

  @@map("profiles")
}

model Client {
  id        String   @id @default(uuid())
  userId    String
  name      String
  contact   String? // email/電話/Line等聯絡方式自由文字
  note      String?
  createdAt DateTime @default(now())

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  quotes  Quote[]

  @@index([userId])
  @@map("clients")
}

enum QuoteStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
}

enum TaxMode {
  NONE // 未稅，原價顯示
  BUSINESS_5PCT // 營業稅5%（開發票）
  LABOR_INCOME_10PCT // 勞務報酬二代健保+10%代扣
}

model Quote {
  id          String      @id @default(uuid())
  userId      String
  clientId    String
  title       String
  status      QuoteStatus @default(DRAFT)
  taxMode     TaxMode     @default(NONE)
  shareToken  String      @unique @default(uuid()) // 給客戶看的公開分享連結用
  sentAt      DateTime?
  respondedAt DateTime?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  profile    Profile      @relation(fields: [userId], references: [id], onDelete: Cascade)
  client     Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  items      QuoteItem[]
  receivable Receivable?

  @@index([userId])
  @@index([clientId])
  @@map("quotes")
}

model QuoteItem {
  id        String   @id @default(uuid())
  quoteId   String
  name      String
  unitPrice Decimal  @db.Decimal(12, 2)
  quantity  Decimal  @db.Decimal(12, 2) @default(1)
  sortOrder Int      @default(0)

  quote Quote @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
  @@map("quote_items")
}

enum ReceivableStatus {
  PENDING
  PAID
}

model Receivable {
  id        String           @id @default(uuid())
  userId    String
  quoteId   String           @unique
  amount    Decimal          @db.Decimal(12, 2)
  status    ReceivableStatus @default(PENDING)
  dueDate   DateTime?
  paidAt    DateTime?
  createdAt DateTime         @default(now())

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)
  quote   Quote   @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("receivables")
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id          String          @id @default(uuid())
  userId      String
  type        TransactionType
  amount      Decimal         @db.Decimal(12, 2)
  category    String?
  note        String?
  occurredAt  DateTime
  createdAt   DateTime        @default(now())

  profile Profile @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([occurredAt])
  @@map("transactions")
}
